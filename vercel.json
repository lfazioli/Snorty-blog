{
  "functions": {
    "api/posts.ts": { "runtime": "nodejs20.x" },
    "api/auth/register.ts": { "runtime": "nodejs20.x" },
    "api/auth/login.ts": { "runtime": "nodejs20.x" },
    "api/auth/logout.ts": { "runtime": "nodejs20.x" },
    "api/auth/forgot.ts": { "runtime": "nodejs20.x" },
    "api/auth/reset.ts": { "runtime": "nodejs20.x" }
  },
  "routes": [
    { "src": "/api/posts", "dest": "api/posts.ts" },
    { "src": "/api/auth/register", "dest": "api/auth/register.ts" },
    { "src": "/api/auth/login", "dest": "api/auth/login.ts" },
    { "src": "/api/auth/logout", "dest": "api/auth/logout.ts" },
    { "src": "/api/auth/forgot", "dest": "api/auth/forgot.ts" },
    { "src": "/api/auth/reset", "dest": "api/auth/reset.ts" }
  ]
}
